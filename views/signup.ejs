<html lang="en">
<head>
    <%- include('./partials/head)%>

    <title>Signup</title>
</head>
<body>
    <%- include('./partials/nav')%>
    <div class = "container mt-5">
        <form action = "/user/signup" method = "post">
            <div class=" mb -3">
                <label for = "exampleFullName" class = "form-label">Full Name</label>
                <input type="text" class = "from-control" name = "fullName" id = "exampleFullName">

            </div>
            <div class = "mb-3">
                <label for = "exampleInputEmail" class ="from-label">Email address</label>
                <input type="email" class="form-control" id=" exampleInputEmail" name="email" aria-describedby="emailHelp">
                <div id="emailHelp" class=" form -text">We'll Never Share  your Email</div>
                
            </div>

            <div class="mb-3">
              <label for="exampleInputPassword1" class="form-label">Password</label>
              <input type="password" class="form-control" id="exampleInputPassword1" name="password">
            </div>
           
            <button type="submit" class="btn btn-primary">Submit</button>
          </form>
    </div>
    <%- include('./partials/scripts') %>
        
</body>
</html>